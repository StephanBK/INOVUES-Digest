# INOVUES Digest — Environment Variables
# Copy this to .env and fill in your values

# Anthropic API key (for Claude curation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Gmail credentials
GMAIL_USER=sketterer@inovues.com
GMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx   # Google App Password (not your regular password)

# Recipients (comma-separated)
RECIPIENTS=sketterer@inovues.com

# Optional: Brave Search API for better news (https://api.search.brave.com)
# If not set, falls back to GNews
BRAVE_API_KEY=

# Optional: GNews API key (https://gnews.io) - free tier available
GNEWS_API_KEY=
